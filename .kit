# kit's own tasks — dogfooding. Run `kit build`, `kit test`.

build: compile kit into bin/
    go build -o bin/kit.exe ./cmd/kit

test: run every package test
    go test ./...

install: install kit into GOPATH/bin
    go install ./cmd/kit

msi: build the Windows installer (needs WiX: dotnet tool install --global wix)
    go build -o bin/kit.exe ./cmd/kit
    wix build installer/kit.wxs -arch x64 -d Version=0.1.0 -o bin/kit.msi
