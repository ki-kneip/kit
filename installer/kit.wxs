<?xml version="1.0" encoding="utf-8"?>
<!-- WiX v4+ source for kit's Windows installer.
     Build (from the repo root):
       1. dotnet tool install -g wix              (once; needs the .NET SDK)
       2. kit msi                                 (or: wix build installer/kit.wxs -arch x64 -d Version=0.1.0 -o bin/kit.msi)
     Installs kit.exe into Program Files\kit and appends it to the system PATH.
     Version comes from the -d Version=X.Y.Z preprocessor variable; defaults
     to 0.1.0 when built without it (plain "kit msi" during development). -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <?ifndef Version?>
  <?define Version = "0.1.0"?>
  <?endif?>
  <Package Name="kit"
           Manufacturer="Ki Kneip"
           Version="$(Version)"
           UpgradeCode="DD05559E-5D15-4492-9117-DEDAF577FF2C"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of kit is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="kit">
        <Component Id="KitExe">
          <File Id="KitExe" Source="..\bin\kit.exe" KeyPath="yes" />
          <Environment Id="KitPath"
                       Name="PATH"
                       Value="[INSTALLFOLDER]"
                       Permanent="no"
                       Part="last"
                       Action="set"
                       System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentRef Id="KitExe" />
    </Feature>
  </Package>
</Wix>
